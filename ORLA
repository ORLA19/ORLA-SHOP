<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ORLA Fashion</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f8f8f8;
        }

        header {
            background-color: #000;
            color: #fff;
            padding: 15px;
            text-align: center;
            font-size: 24px;
            letter-spacing: 2px;
        }

        nav {
            display: flex;
            justify-content: center;
            gap: 20px;
            background-color: #fff;
            padding: 10px;
            border-bottom: 1px solid #ddd;
        }

        nav a {
            text-decoration: none;
            color: #000;
            font-weight: bold;
        }

        .hero {
            text-align: center;
            padding: 60px 20px;
            background-color: #eee;
        }

        .hero h1 {
            font-size: 36px;
        }

        .hero p {
            max-width: 600px;
            margin: 10px auto;
            color: #555;
        }

        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background-color: black;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        .products {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            padding: 40px;
        }

        .product {
            background: #fff;
            padding: 15px;
            text-align: center;
            border-radius: 10px;
        }

        .product img {
            width: 100%;
            border-radius: 10px;
        }

        footer {
            text-align: center;
            padding: 20px;
            background-color: #000;
            color: white;
        }
    </style>
</head>
<body>

<header>ORLA</header>

<nav>
    <a href="#">Home</a>
    <a href="#">Shop</a>
    <a href="#">New</a>
    <a href="#">Contact</a>
</nav>

<section class="hero">
    <h1>Effortless Style, Everyday</h1>
    <p>Discover modern fashion with perfect fit and everyday value. Dress with confidence for any occasion.</p>
    <a href="#" class="btn">Shop Now</a>
</section>

<section class="products">
    <div class="product">
        <img src="https://via.placeholder.com/200" alt="Product">
        <h3>Basic T-Shirt</h3>
        <p>$20</p>
    </div>

    <div class="product">
        <img src="https://via.placeholder.com/200" alt="Product">
        <h3>Casual Jacket</h3>
        <p>$45</p>
    </div>

    <div class="product">
        <img src="https://via.placeholder.com/200" alt="Product">
        <h3>Denim Jeans</h3>
        <p>$35</p>
    </div>
</section>

<footer>
    © 2026 ORLA Fashion. All rights reserved.
</footer>

</body>
</html>
